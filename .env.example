# ===== Bot mode =====
MODE=paper
BOT_SYMBOL=MBT
TIMEFRAME_MINUTES=15

# ===== Apex EOD Eval (50k) =====
ACCOUNT_SIZE=50000
PROFIT_TARGET_USD=3000
EOD_MAX_DRAWDOWN_USD=2000
DAILY_LOSS_LIMIT_USD=1000

MAX_CONTRACTS=6
CONTRACTS_PER_TRADE=1
STOP_TRADING_ON_TARGET=true

# ===== ML =====
ML_ENABLED=true
ML_MIN_PROB=0.55
SIGNAL_MODEL_PATH=models/signal_model.joblib

# ===== Optimizer =====
N_TRIALS=10000
N_FOLDS=4
WF_TRAIN_BARS=8000
WF_TEST_BARS=2000
WF_STEP_BARS=2000
SAVE_TRADE_SAMPLES=1

# ===== Tradovate (Option A REST) =====
TRADOVATE_ENV=demo
TRADOVATE_BASE_DEMO=https://demo.tradovateapi.com/v1
TRADOVATE_BASE_LIVE=https://live.tradovateapi.com/v1

TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=

# ===== Mode =====
MODE=live                 # paper | demo | live
I_UNDERSTAND_LIVE_TRADING=false

# ===== Tradovate =====
TRADOVATE_ENV=demo         # demo | live
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_DEVICE_ID=
TRADOVATE_API_SECRET=
TRADOVATE_ACCOUNT_ID=      # optional
TRADOVATE_SYMBOL=MBT

# ===== Streaming / polling intervals =====
QUOTE_STALE_SECONDS=5
BALANCE_POLL_SECONDS=10

# ===== Daily retrain schedule (local VPS time) =====
RETRAIN_DAILY=true
RETRAIN_HOUR=2
RETRAIN_MINUTE=0
TRADOVATE_DEVICE_ID=
TRADOVATE_API_SECRET=
TRADOVATE_ACCOUNT_ID=
TRADOVATE_SYMBOL=MBT

# Safety guard
BALANCE_STALE_SECONDS=30
QUOTE_STALE_SECONDS=5
